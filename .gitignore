# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.venv-linux

# dotenv files
ai-dm-sicord-bot/cred.env
oracle-dm-backend/backend-cred.env

# databases (runtime + throwaway demo DBs)
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal
*.db-journal
oracle.db
oracle-dm-backend/oracle.db
eight_card_system/demo_world.db
rules/demo_rules.db

# launcher build artifacts (PyInstaller spec is regenerated on build)
launcher/*.spec
launcher/launcher_error.log

# Lavalink runtime (auto-downloaded plugins + logs)
ai-dm-sicord-bot/plugins/
ai-dm-sicord-bot/lavalink.log
ai-dm-sicord-bot/lavalink-error.log
ai-dm-sicord-bot/logs/

# generic runtime logs
*.log

# voice-service runtime/secrets
voice-service/node_modules/
voice-service/.env
voice-service/*.log

# Local-only owned-book extraction workspace (never commit book content)
owned_books/

# Design references (external inspiration art) + generated art proofs —
# never commit the source images or the diffusion examples; the README + the
# HTML mockup (self-contained, no external assets) may still be committed.
docs/design/references/*.jpg
docs/design/references/*.jpeg
docs/design/references/*.png
docs/design/references/*.webp
docs/design/proofs/

# Generated species portraits (owned-book species must stay local; SRD/PHB ones
# can be force-added: git add -f activity-ui/public/assets/species/<slug>-*.webp)
activity-ui/public/assets/species/
