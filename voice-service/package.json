    "node": ">=22.12.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.6",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ffmpeg-static": "^5.2.0",
    "opusscript": "^0.0.8",
    "youtube-dl-exec": "^3.0.10"
  },
  "optionalDependencies": {
    "@discordjs/opus": "^0.9.0",
    "sodium-native": "^4.1.1"
  }
}
