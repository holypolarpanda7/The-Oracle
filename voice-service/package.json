{
  "name": "oracle-voice-service",
  "version": "1.0.0",
  "private": true,
  "description": "DAVE-capable Discord voice sidecar for The Oracle. Owns voice connections and audio playback so the Python bot doesn't have to (discord.py/Lavalink lack DAVE/E2EE support, close code 4017).",
