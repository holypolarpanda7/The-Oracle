# Voice-service config. All optional — the Python bot passes these via env when
# it spawns the sidecar, and the shared bot token is read from
# ../ai-dm-sicord-bot/cred.env (ORACLE_DM_TOKEN) as a fallback.

# Override the bot token (defaults to ORACLE_DM_TOKEN from cred.env)
# DISCORD_TOKEN=

# HTTP control API bind address / port
VOICE_SERVICE_HOST=127.0.0.1
VOICE_SERVICE_PORT=8790

# Optional shared secret; when set, callers must send X-Voice-Token
# VOICE_SERVICE_SECRET=

# Default playback volume (0-100)
VOICE_SERVICE_DEFAULT_VOLUME=50
